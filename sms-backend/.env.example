# Variables d'environnement à configurer sur Vercel (Settings → Environment Variables)
# Ne PAS commiter le vrai .env dans Git !

# Twilio — Compte (https://console.twilio.com)
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=votre_auth_token_twilio

# Expéditeur SMS
# Option 1 : Alphanumeric Sender ID (gratuit, fonctionne en LU/FR/DE, max 11 caractères, sans espaces)
TWILIO_FROM=PetitsGen
# Option 2 (alternative) : numéro Twilio acheté (~$1/mois en LU)
# TWILIO_FROM=+352XXXXXXXX

# Téléphone de l'académie (recevra une notification SMS pour chaque inscription)
# Format international obligatoire, ex: +352123456789 ou +33612345678
ACADEMY_PHONE=+352XXXXXXXXX
